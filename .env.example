# Neon Postgres connection string (get one from https://neon.tech or the Vercel→Neon integration).
# Copy this file to .env.local and paste your real value. Never commit .env.local.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# A long random string used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"
